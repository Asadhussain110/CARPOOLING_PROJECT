@model CARPOOLING_PROJECT.ViewModels.LoginViewModel
@{
    ViewBag.Title = "Login";
}

<section class="auth-wrapper mt-4">
    <div class="auth-hero">
        <span class="eyebrow-badge text-uppercase text-muted">PakiCarpool Login</span>
        <h2 class="mb-3">Welcome back to the road.</h2>
        <p class="text-muted">
            Sign in as an admin to moderate the network, as a driver to manage rides,
            or as a passenger to hop into trusted carpools across Pakistan.
        </p>
        <ul class="list-unstyled mt-3 text-muted">
            <li>• Real-time approvals & bans for safe journeys</li>
            <li>• Live seat availability and stop management</li>
            <li>• Ratings & payments to keep every ride transparent</li>
        </ul>
    </div>
    <div class="glass-card p-4">
        <h4 class="mb-3">Login to continue</h4>
        @using (Html.BeginForm())
        {
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="mb-3">
                @Html.LabelFor(m => m.Email, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.Email, new { @class = "form-control form-control-lg", placeholder = "you@example.com" })
                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3">
                @Html.LabelFor(m => m.Password, new { @class = "form-label" })
                @Html.PasswordFor(m => m.Password, new { @class = "form-control form-control-lg", placeholder = "Enter password" })
                @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
            </div>

            <div class="mb-4">
                <label class="form-label">Login as</label>
                <div class="role-card-group">
                    <label class="role-card">
                        @Html.RadioButtonFor(m => m.SelectedRole, "Admin", new { @class = "d-none", autocomplete = "off" })
                        <h5>Admin</h5>
                        <p>Moderate drivers, passengers, bans and approvals.</p>
                    </label>
                    <label class="role-card">
                        @Html.RadioButtonFor(m => m.SelectedRole, "Driver", new { @class = "d-none", autocomplete = "off" })
                        <h5>Driver</h5>
                        <p>Post rides, manage routes, and earn per seat.</p>
                    </label>
                    <label class="role-card">
                        @Html.RadioButtonFor(m => m.SelectedRole, "Passenger", new { @class = "d-none", autocomplete = "off" })
                        <h5>Passenger</h5>
                        <p>Find rides, reserve seats, and rate trips.</p>
                    </label>
                </div>
                @Html.ValidationMessageFor(m => m.SelectedRole, "", new { @class = "text-danger" })
            </div>

            <button type="submit" class="btn btn-primary w-100 btn-lg shadow-sm">Login</button>
        }

        <div class="mt-4">
            <small class="text-muted d-block mb-2">Need an account?</small>
            <div class="d-flex flex-column flex-md-row gap-2">
                <a class="btn btn-outline-secondary w-100" href="@Url.Action("RegisterPassenger", "Account")">Register as Passenger</a>
                <a class="btn btn-outline-secondary w-100" href="@Url.Action("RegisterDriver", "Account")">Register as Driver</a>
            </div>
        </div>
    </div>
</section>

