@using System
@{
    var displayName = Session["DisplayName"] as string;
    var role = Session["Role"] as string;
    var siteName = "PakiCarpool";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title - @siteName</title>

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/Content/site.css?v=3" />

    @RenderSection("Styles", required: false)
</head>
<body>

    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark brand-navbar" aria-label="Primary">
        <div class="container-fluid px-4">
            <a class="navbar-brand" href="@Url.Action("Index", "Home")">@siteName</a>
            <button class="navbar-toggler text-white" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse justify-content-end" id="mainNav">
                <ul class="navbar-nav mb-2 mb-lg-0 align-items-lg-center">
                    @if (string.IsNullOrEmpty(displayName))
                    {
                        <li class="nav-item ms-4">
                            <a class="btn btn-outline-light btn-lg ms-2" href="@Url.Action("Login", "Account")">Login</a>
                        </li>
                        <li class="nav-item ms-4">
                            <a class="btn btn-primary btn-lg ms-2" href="@Url.Action("Index", "Home")#register-options">Register</a>
                        </li>
                    }
                    else if (string.Equals(role, "Admin", StringComparison.OrdinalIgnoreCase))
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Dashboard", "Admin")">Dashboard</a>
                        </li>
                    }
                    else if (string.Equals(role, "Driver", StringComparison.OrdinalIgnoreCase))
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Dashboard", "Driver")">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("PostRide", "Driver")">Post Ride</a>
                        </li>
                    }
                    else if (string.Equals(role, "Passenger", StringComparison.OrdinalIgnoreCase))
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Dashboard", "Passenger")">Dashboard</a>
                        </li>
                    }
                    @if (!string.IsNullOrEmpty(displayName))
                    {
                        <li class="nav-item d-flex align-items-center">
                            <span class="navbar-text text-white me-lg-3 fs-5 fw-bold">@displayName (@role)</span>
                        </li>
                        <li class="nav-item ms-4">
                            <a class="btn btn-primary btn-lg ms-2 shadow-sm" href="@Url.Action("Logout", "Account")">Logout</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main content -->
    <main id="main-content" class="app-shell container-fluid px-4" tabindex="-1">
        @if (TempData["Message"] != null)
        {
            <div class="alert alert-success mb-4" role="status" aria-live="polite">@TempData["Message"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger mb-4" role="alert" aria-live="assertive">@TempData["Error"]</div>
        }
        @RenderBody()
    </main>

    <!-- jQuery 3.7.1 from CDN -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"
            integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0="
            crossorigin="anonymous"></script>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
