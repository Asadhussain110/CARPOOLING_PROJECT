@{
    var displayName = Session["DisplayName"] as string;
    var role = Session["Role"] as string;
    var siteName = "PakiCarpool";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="PakiCarpool - Pakistan's trusted carpooling network connecting verified drivers and passengers. Share rides, save money, and travel safely with admin-approved drivers, real-time route management, and cash payments." />
    <title>@ViewBag.Title - @siteName</title>

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/Content/site.css?v=4" />

    @RenderSection("Styles", required: false)
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark brand-navbar">
        <div class="container-xl">
            <a class="navbar-brand" href="@Url.Action("Index", "Home")">@siteName</a>
            <button class="navbar-toggler text-white" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse justify-content-end" id="mainNav">
                <ul class="navbar-nav mb-2 mb-lg-0 align-items-lg-center">
                    @if (!string.IsNullOrEmpty(displayName))
                    {
                        <li class="nav-item">
                            <span class="navbar-text me-lg-3">@displayName (@role)</span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link btn-pill" href="@Url.Action("Logout", "Account")">Logout</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main content -->
    <main class="app-shell container-xl">
        @if (TempData["Message"] != null)
        {
            <div class="alert alert-success mb-4">@TempData["Message"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger mb-4">@TempData["Error"]</div>
        }
        @RenderBody()
        <footer class="site-footer">
            <span>PakiCarpool</span> — Share rides, save more. Trusted carpooling across Pakistan.
        </footer>
    </main>

    <!-- jQuery 3.7.1 from CDN -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"
            integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0="
            crossorigin="anonymous"></script>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
